# 企業横断オペレーション基盤（EOH）バックエンド 本番用環境変数
# コピー: cp .env.production.example .env

# 本番運用モード（必須）
ENVIRONMENT=production

# シークレットキー（必須・openssl rand -hex 32 で生成）
EOH_SECRET_KEY=your-eoh-secret-key-here

# データベースURL（本番はPostgreSQL推奨）
# EOH_DATABASE_URL=postgresql://user:pass@host:5432/eoh_db
# 未設定時は SQLite (eoh.db) を使用

# CORS設定（フロントエンドのオリジン・カンマ区切り）
EOH_CORS_ORIGINS=https://eoh.your-domain.com,https://your-domain.com

# ポート（デフォルト 9020）
# EOH_PORT=9020
