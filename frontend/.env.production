# UEP v5.0 フロントエンド 本番用設定（要設定項目を反映済み）
# 本番ドメイン: python scripts/set-production-domain.py your-domain.com で一括更新

REACT_APP_API_URL=http://localhost:8080
REACT_APP_ENV=production

# Sentry（https://sentry.io でプロジェクト作成後、DSNを設定）
REACT_APP_SENTRY_DSN=

REACT_APP_INDUSTRY_UNIFIED_URL=http://localhost:3010
REACT_APP_EOH_URL=http://localhost:3020
