# UEP v5.0 フロントエンド 本番用環境変数
# ビルド時に使用: cp .env.production.example .env.production
# または CI/CD で設定

# UEP バックエンド API URL（必須）
REACT_APP_API_URL=https://api.your-domain.com

# 産業統合プラットフォームのURL（ダッシュボード・サイドバーからのリンク先）
REACT_APP_INDUSTRY_UNIFIED_URL=https://industry.your-domain.com

# 企業横断オペレーション基盤（EOH）のURL（ダッシュボード・サイドバーからのリンク先）
REACT_APP_EOH_URL=https://eoh.your-domain.com
