# UEP フロントエンド 環境変数
# コピーして .env として使用: cp .env.example .env

# UEP バックエンド API URL（未設定時: http://localhost:8080）
REACT_APP_API_URL=http://localhost:8080

# 産業統合プラットフォームのURL（ダッシュボード・サイドバーからのリンク先）
# 未設定時は http://localhost:3010 を使用
REACT_APP_INDUSTRY_UNIFIED_URL=http://localhost:3010

# 企業横断オペレーション基盤のURL（ダッシュボード・サイドバーからのリンク先）
# 未設定時は http://localhost:3020 を使用
REACT_APP_EOH_URL=http://localhost:3020
