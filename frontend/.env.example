# UEP v5.0 フロントエンド 本番用環境変数サンプル
# 本番ビルド前に必ず設定を確認してください

# API ベースURL（本番バックエンドのURL）
REACT_APP_API_URL=https://api.your-domain.com

# 環境識別（Sentry等で使用）
REACT_APP_ENV=production

# Sentry エラー収集（オプション・本番推奨）
# https://sentry.io でプロジェクト作成後、DSNを設定
REACT_APP_SENTRY_DSN=

# 外部アプリURL（産業統合・EOH等）
REACT_APP_INDUSTRY_UNIFIED_URL=https://industry.your-domain.com
REACT_APP_EOH_URL=https://eoh.your-domain.com

# MSW モック（開発時のみ・本番では未設定）
# REACT_APP_ENABLE_MSW=true
