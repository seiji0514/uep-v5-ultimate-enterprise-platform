# UEP v5.0 + 産業統合プラットフォーム HTTPS リバースプロキシ設定例
# /etc/nginx/sites-available/uep に配置し、シンボリックリンクで有効化
# sudo ln -s /etc/nginx/sites-available/uep /etc/nginx/sites-enabled/

# Let's Encrypt で証明書取得: certbot --nginx -d your-domain.com -d industry.your-domain.com

# UEP フロントエンド（ポート 3000）
# 産業統合フロントエンド（ポート 3010）
# UEP バックエンド（ポート 8080）
# 産業統合バックエンド（ポート 9010）

upstream uep_frontend {
    server 127.0.0.1:3000;
}
upstream industry_frontend {
    server 127.0.0.1:3010;
}
upstream uep_backend {
    server 127.0.0.1:8080;
}
upstream industry_backend {
    server 127.0.0.1:9010;
}

# UEP メイン（https://your-domain.com）
server {
    listen 443 ssl http2;
    server_name your-domain.com;

    ssl_certificate /etc/letsencrypt/live/your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;

    location / {
        proxy_pass http://uep_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# 産業統合プラットフォーム（https://industry.your-domain.com）
server {
    listen 443 ssl http2;
    server_name industry.your-domain.com;

    ssl_certificate /etc/letsencrypt/live/industry.your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/industry.your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://industry_frontend;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# UEP API（https://api.your-domain.com）
server {
    listen 443 ssl http2;
    server_name api.your-domain.com;

    ssl_certificate /etc/letsencrypt/live/api.your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://uep_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# 産業統合 API（https://api-industry.your-domain.com）
server {
    listen 443 ssl http2;
    server_name api-industry.your-domain.com;

    ssl_certificate /etc/letsencrypt/live/api-industry.your-domain.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api-industry.your-domain.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;

    location / {
        proxy_pass http://industry_backend;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
