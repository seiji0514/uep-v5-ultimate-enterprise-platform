# UEP v5.0 本番運用 環境変数
# コピーして .env として使用し、値を本番用に設定してください

# === 必須 ===
ENVIRONMENT=production
DEBUG=false

# 本番では必ず変更（openssl rand -hex 32 で生成推奨）
SECRET_KEY=your-production-secret-key-min-32-chars

# PostgreSQL（本番推奨）
DATABASE_URL=postgresql://user:password@host:5432/uep_db

# Redis（セッション・キャッシュ用）
REDIS_URL=redis://:password@host:6379/0

# CORS（フロントエンドのオリジンを指定）
CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# === 推奨 ===
LOG_LEVEL=WARNING
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
CSRF_ENABLED=true

# MinIO / S3（オブジェクトストレージ）
MINIO_ENDPOINT=your-minio-or-s3-endpoint
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_SECURE=true

# Kafka（イベントストリーミング）
KAFKA_BOOTSTRAP_SERVERS=your-kafka:9092

# === 産業統合プラットフォーム（industry_unified_platform 起動時） ===
# CORS_ORIGINS に産業統合フロントのドメインを含める
# INDUSTRY_UNIFIED_HOST=0.0.0.0
# INDUSTRY_UNIFIED_PORT=9010

# === 本番ユーザー永続化 ===
# 設定すると登録ユーザーが JSON ファイルに保存され、再起動後も維持されます
# PRODUCTION_USERS_FILE=./data/production_users.json
