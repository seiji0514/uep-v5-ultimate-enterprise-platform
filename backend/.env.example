# UEP v5.0 バックエンド 本番用環境変数サンプル
# 本番デプロイ前に必ず設定を確認してください

# 環境
ENVIRONMENT=production
DEBUG=false

# サーバー
HOST=0.0.0.0
PORT=8080

# データベース（本番はPostgreSQL推奨）
DATABASE_URL=postgresql://user:password@localhost:5432/uep_db

# Redis（レート制限・キャッシュ用）
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# セキュリティ（本番では必ず変更）
SECRET_KEY=your-very-long-random-secret-key-change-this
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS（本番フロントのオリジンを指定）
# カンマ区切り: https://app.example.com,https://admin.example.com
CORS_ORIGINS=https://your-frontend-domain.com

# レート制限
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# 本番ユーザーファイル（オプション）
PRODUCTION_USERS_FILE=./data/production_users.json
