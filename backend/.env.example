# 環境変数設定例（本番運用）
# .envファイルとしてコピーして使用してください

# 本番運用モード
ENVIRONMENT=production
DEBUG=false

# シークレットキー（必須・openssl rand -hex 32 で生成）
SECRET_KEY=your-secret-key-here

# データベースURL
DATABASE_URL=sqlite:///./uep_db.sqlite
# PostgreSQL: DATABASE_URL=postgresql://user:pass@host:5432/uep_db

# Redis URL
REDIS_URL=redis://localhost:6379/0

# ログレベル
LOG_LEVEL=WARNING

# CORS設定（フロントエンドのオリジン）
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# トークン有効期限（分）※面談中ログアウト防止は 120 推奨
ACCESS_TOKEN_EXPIRE_MINUTES=120

# 本番ユーザー永続化（設定すると登録ユーザーがファイルに保存され再起動後も維持）
PRODUCTION_USERS_FILE=./data/production_users.json
