# 産業統合プラットフォーム バックエンド 環境変数
# コピーして .env として使用: cp .env.example .env
# ※ backend/.env に配置（main.py は backend を cwd とする）

# 本番運用モード（production でデモシード無効・API docs 無効）
ENVIRONMENT=production
DEBUG=false

# CORS（フロントエンドのオリジンをカンマ区切りで指定。本番では * を避ける）
CORS_ORIGINS=https://industry.your-domain.com,https://your-domain.com

# listen ホスト（本番: 0.0.0.0）
INDUSTRY_UNIFIED_HOST=0.0.0.0
INDUSTRY_UNIFIED_PORT=9010
